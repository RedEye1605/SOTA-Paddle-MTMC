# =============================================================================
# SOTA-Paddle-MTMC — operational + secrets
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# --- Runtime ------------------------------------------------------------------
LOG_LEVEL=INFO
HEADLESS=true
DRAWING_ENABLED=false
SOTA_API_TOKEN=

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_HOST=relation-store
POSTGRES_PORT=5432
POSTGRES_DB=yamaha_mtmct
POSTGRES_USER=yamaha
POSTGRES_PASSWORD=
POSTGRES_POOL_SIZE=10
POSTGRES_POOL_MAX_OVERFLOW=20

# --- Qdrant -------------------------------------------------------------------
QDRANT_HOST=vector-store
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# --- Redis --------------------------------------------------------------------
REDIS_HOST=message-bus
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- MinIO --------------------------------------------------------------------
# Production points at your external managed MinIO. The 3 buckets below
# give the operator explicit control over evidence / reports / models
# without forcing a single shared bucket. Leave any *_BUCKET empty to
# disable uploads to that bucket. Never commit real access keys here.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=
MINIO_BUCKET_EVIDENCE=
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_MODELS=models

# --- MQTT / ThingsBoard -------------------------------------------------------
# Production points at your external broker. Never commit broker
# credentials or device tokens here.
#
# USE_LEGACY_MQTT_CONTRACT:
#   - true  (default): publish per-camera to
#     ai/yamaha/people-detection/{cam1|cam2}/summary  with the legacy
#     ThingsBoard {ts, values} payload. Used when no
#     THINGSBOARD_DEVICE_TOKEN is set.
#   - false: fall back to the new v1/devices/me/telemetry contract.
#
# The legacy client_id format people_counter_<device_name>_<ts>_<rand>
# is also adopted automatically when USE_LEGACY_MQTT_CONTRACT=true.
USE_LEGACY_MQTT_CONTRACT=true
MQTT_ENABLED=true
MQTT_BROKER_HOST=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TLS_ENABLED=false
MQTT_CLIENT_ID=yamaha-mtmct-01
MQTT_QOS=1
MQTT_TOPIC_BASE=ai/yamaha/people-detection
MQTT_TOPIC=
THINGSBOARD_DEVICE_TOKEN=
# External ThingsBoard / broker host (preferred over MQTT_BROKER_HOST
# when set). The two are kept in sync: if MQTT_HOST is non-empty the
# publisher uses it. Format: bare hostname, optional :port suffix.
MQTT_HOST=
MQTT_PORT=1883

# --- MediaMTX (external) ------------------------------------------------------
# External MediaMTX. Use your deployed RTSP/HLS/WebRTC hosts here.
MEDIAMTX_ENABLED=true
MEDIAMTX_PROTOCOL=rtsp
MEDIAMTX_HOST=
MEDIAMTX_HLS_HOST=
MEDIAMTX_WEBRTC_HOST=
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_RTMP_PORT=1935
MEDIAMTX_HLS_PORT=8889
MEDIAMTX_WEBRTC_PORT=8890
MEDIAMTX_STREAM_PREFIX=sota-paddle-mtmc
# RTSP publish URL template. {host}, {port}, {prefix}, {camera_id} are
# substituted by the streamer. Leave blank to use the default
# rtsp://{host}:{port}/{prefix}/{camera_id} form.
MEDIAMTX_PUBLISH_URL_TEMPLATE=
# PP-Human direct RTSP push. When true, the PP-Human pipeline
# subprocess is launched with ``--pushurl`` so it publishes its
# ANNOTATED stream (with bboxes burned in by PP-Human's own
# visualiser) directly to MediaMTX. Our ffmpeg streamer is then
# redundant and should be disabled (MEDIAMTX_ENABLED=false).
#
# When this is true AND MEDIAMTX_ENABLED is also true, two ffmpeg
# instances will fight for the same MediaMTX path; startup will
# log a loud warning and prefer the PP-Human direct path.
#
# PUSHURL_BASE: the RTSP base URL PP-Human publishes to. The
# pipeline joins the basename of the input file onto the end, so
# /data/cam1_merged.mp4 with the default base publishes to
# rtsp://<mediamtx-host>:8554/sota-paddle-mtmc/cam1_merged.
MEDIAMTX_PPHUMAN_DIRECT_PUSH=true
MEDIAMTX_PUSHURL_BASE=
# FFmpeg
FFMPEG_BIN=ffmpeg
MEDIAMTX_FPS=10
MEDIAMTX_BITRATE_KBPS=1800
MEDIAMTX_WIDTH=960
MEDIAMTX_HEIGHT=540

# --- Models -------------------------------------------------------------------
# Optional override of PPHUMAN_MODEL_DIR / TRANSREID_WEIGHT / etc.
PPHUMAN_MODEL_DIR=/models/pphuman
# PATCH (2026-06-15, operator spec, transreid-only): the only
# active ReID is TransReID MSMT17 (vit_transreid_msmt.pth, 3840-dim
# cosine). The api image is Paddle-only; the reid-sidecar service
# (built from the repo Dockerfile) loads the real torch model.
TRANSREID_WEIGHT=/models/vit_transreid_msmt.pth
TRANSREID_SIDECAR_PROFILE=msmt17
REID_SIDECAR_DEVICE=cuda

# --- Smoke / benchmark knobs --------------------------------------------------
SMOKE_MAX_FRAMES=300
SMOKE_MAX_SECONDS=30
BENCHMARK_OUT_DIR=/tmp/sota_paddle_mtmct_bench

# --- Legacy integration contract toggles (Phase 5b) ---------------------------
# These flags let the operator align the new pipeline with the legacy
# Service/offline-people-counting behavior. They only affect
# visualization (SHOW_*) and outbound integration (ENABLE_*); they
# do NOT change internal counting, tracking, or benchmark metrics.
#
# All flags default to "true" so out-of-the-box behaviour matches
# the legacy pipeline. Set ENABLE_SEND_MQTT=false to run the pipeline
# without publishing anything to the broker.
ENABLE_SEND_MQTT=true
ENABLE_MINIO_UPLOAD=true
ENABLE_TRACK_ID=true
SHOW_ROI_ZONES=true
SHOW_CONFIDENCE_SCORE=true
SHOW_TRACK_ID=true
SHOW_DETECTION_BOX=true
SHOW_CAMERA_LABEL=true
SHOW_COUNTING_OVERLAY=true

# --- Legacy contract overrides (Phase 5b) -------------------------------------
# These values match the legacy Service/offline-people-counting
# defaults. They are documented here so the operator can see the
# expected contract; the actual values are loaded from
# configs/legacy/offline_people_counting.yaml. The YAML is the
# source of truth — env vars override it on a per-key basis.
#
# MQTT topic base:   ai/yamaha/people-detection
# MQTT topic CAM_01: ai/yamaha/people-detection/cam1/summary
# MQTT topic CAM_02: ai/yamaha/people-detection/cam2/summary
# MinIO bucket:      yamaha-poc
# MinIO prefix:      people-detection
# RTSP port:         8554
# HLS port:          8889
# WebRTC port:       8890

# --- SAHI integration (2026-06-16) ------------------------------------------
# Master switch for the SAHI worker. Default is OFF in production; enable
# per-environment. When false, the SAHI worker is constructed but not
# started (see Task 7: wire SAHIWorker into app/main.py lifecycle).
SAHI_ENABLED=false

# SAHI configuration (all have sensible defaults; override per-env if needed)
SAHI_PATCH_SIZE=320
SAHI_OVERLAP_RATIO=0.2
SAHI_MIN_AREA=30
SAHI_NMS_IOU=0.5
SAHI_FILTER_THRESHOLD=0.4
SAHI_UNION_NMS_IOU=0.5
SAHI_UNION_MIN_CONF=0.4
SAHI_STALE_MS=400
SAHI_TIMESTAMP_SLACK_MS=50
SAHI_RTSP_URLS=rtsp://mediamtx:8554/cam1_merged/,rtsp://mediamtx:8554/cam2_merged/
SAHI_RATE_LIMIT_HZ=5.0
SAHI_DEVICE=gpu:0
SAHI_LATEST_KEY_PREFIX=sahi:latest:
SAHI_STREAM=stream:detections_sahi
